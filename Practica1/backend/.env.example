# ============================================================
# CountryPedia Backend — Variables de Entorno
# ============================================================
# Copia este archivo a .env y completa los valores

# Seguridad
SECRET_KEY= cambia_esta_clave
API_KEY= cambia_esta_api_key

# Base de Datos (Supabase PostgreSQL con Pooler)
# Formato:
#   postgresql://<user>@<project-ref>.pooler.supabase.com:6543/postgres?pgbouncer=true
#   postgresql://<user>@<project-ref>.pooler.supabase.com:5432/postgres (direct)
# Para Session Pooler (recomendado): puerto 6543 con pgbouncer=true
# Para conexión directa: puerto 5432
DATABASE_URL=postgresql://usuario:password@host.pooler.supabase.com:6543/postgres?pgbouncer=true

# APIs Externas
OPENWEATHER_API_KEY= tu_api_key
NEWS_API_KEY= tu_api_key_de_newsapi

# Opcionales (tienen valores por defecto)
# PORT=5000
# HOST=0.0.0.0
# ORIGEN_PERMITIDO=http://localhost:8080,http://localhost:5000
# REST_COUNTRIES_API=https://restcountries.com/v3.1
# EXCHANGE_API=https://api.exchangerate-api.com/v4/latest/USD
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7
# CACHE_EXCHANGE_TTL=86400
