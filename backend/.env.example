# ============================================================
# CountryPedia Backend — Variables de Entorno
# ============================================================
# Copia este archivo a .env y completa los valores
# Nunca subas .env a git (está en .gitignore)

# Seguridad
# SECRET_KEY debe tener al menos 32 bytes para HMAC-SHA256.
# Generar: openssl rand -hex 32
SECRET_KEY=TU_SECRET_KEY_AQUI_DE_32_O_MAS_BYTES

# Base de Datos (Supabase PostgreSQL con Pooler)
# Para Session Pooler (recomendado con gunicorn): puerto 6543 con pgbouncer=true
#   postgresql://<user>@<project-ref>.pooler.supabase.com:6543/postgres?pgbouncer=true
# Para conexión directa: puerto 5432
#   postgresql://<user>@<project-ref>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://usuario:password@host.pooler.supabase.com:6543/postgres?pgbouncer=true

# APIs Externas (opcionales — sin ellas los endpoints devuelven 503)
OPENWEATHER_API_KEY=TU_OPENWEATHER_API_KEY_AQUI
NEWS_API_KEY=TU_NEWS_API_KEY_AQUI

# Opcionales (tienen valores por defecto en core/config.py)
PORT=5000
HOST=0.0.0.0
ORIGEN_PERMITIDO=http://localhost:8080,http://localhost:5000,http://localhost:5173
REST_COUNTRIES_API=https://restcountries.com/v3.1
EXCHANGE_API=https://api.exchangerate-api.com/v4/latest/USD
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7